//@version=5
strategy(title="Range Filter Strategy - Aidesing AI", shorttitle="RF Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.1)

// ══════════════════════════════════════════════════════════════════════════════
// AIDESING AI - Range Filter Strategy
// Optimized for: BTC/USDT 5min, SPY, QQQ, TSLA, NVDA
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// Strategy Settings
grp_STRAT = "Strategy Settings"
startDate = input.time(timestamp("1 Nov 2022 00:00 +0000"), title="Start Date", group=grp_STRAT)
tpPercent = input.float(4.0, title="Take Profit (%)", minval=0.1, maxval=20.0, step=0.1, group=grp_STRAT)
slPercent = input.float(2.0, title="Stop Loss (%)", minval=0.1, maxval=10.0, step=0.1, group=grp_STRAT)
trailingStop = input.bool(true, title="Use Trailing Stop", group=grp_STRAT)
trailingPercent = input.float(2.0, title="Trailing Stop (%)", minval=0.1, maxval=10.0, step=0.1, group=grp_STRAT)

// Range Filter Settings
grp_RF = "Range Filter Settings"
src = input.source(close, title="Source", group=grp_RF)
per = input.int(100, minval=1, title="Sampling Period", group=grp_RF)
mult = input.float(3.0, minval=0.1, step=0.1, title="Range Multiplier", group=grp_RF)

// Visual Settings
grp_VIS = "Visual Settings"
showSignals = input.bool(true, title="Show Buy/Sell Signals", group=grp_VIS)
showBands = input.bool(true, title="Show Target Bands", group=grp_VIS)
showBackground = input.bool(true, title="Show Trend Background", group=grp_VIS)

// ══════════════════════════════════════════════════════════════════════════════
// COLOR VARIABLES
// ══════════════════════════════════════════════════════════════════════════════

upColor = color.new(color.green, 0)
downColor = color.new(color.red, 0)
midColor = color.new(color.gray, 0)
bgUpColor = color.new(color.green, 90)
bgDownColor = color.new(color.red, 90)

// ══════════════════════════════════════════════════════════════════════════════
// RANGE FILTER CALCULATIONS
// ══════════════════════════════════════════════════════════════════════════════

// Smooth Average Range
smoothrng(x, t, m) =>
    wper = t * 2 - 1
    avrng = ta.ema(math.abs(x - x[1]), t)
    smoothrng = ta.ema(avrng, wper) * m
    smoothrng

smrng = smoothrng(src, per, mult)

// Range Filter
rngfilt(x, r) =>
    rngfilt = x
    rngfilt := x > nz(rngfilt[1]) ? x - r < nz(rngfilt[1]) ? nz(rngfilt[1]) : x - r : 
       x + r > nz(rngfilt[1]) ? nz(rngfilt[1]) : x + r
    rngfilt

filt = rngfilt(src, smrng)

// Filter Direction
upward = 0.0
upward := filt > filt[1] ? nz(upward[1]) + 1 : filt < filt[1] ? 0 : nz(upward[1])

downward = 0.0
downward := filt < filt[1] ? nz(downward[1]) + 1 : filt > filt[1] ? 0 : nz(downward[1])

// Target Bands
hband = filt + smrng
lband = filt - smrng

// ══════════════════════════════════════════════════════════════════════════════
// TREND DETERMINATION
// ══════════════════════════════════════════════════════════════════════════════

filtcolor = upward > 0 ? upColor : downward > 0 ? downColor : midColor

barcolor = src > filt and src > src[1] and upward > 0 ? upColor :
           src > filt and src < src[1] and upward > 0 ? upColor : 
           src < filt and src < src[1] and downward > 0 ? downColor : 
           src < filt and src > src[1] and downward > 0 ? downColor : midColor

// ══════════════════════════════════════════════════════════════════════════════
// SIGNALS
// ══════════════════════════════════════════════════════════════════════════════

longCond = bool(na)
shortCond = bool(na)

longCond := src > filt and src > src[1] and upward > 0 or 
            src > filt and src < src[1] and upward > 0

shortCond := src < filt and src < src[1] and downward > 0 or 
             src < filt and src > src[1] and downward > 0

CondIni = 0
CondIni := longCond ? 1 : shortCond ? -1 : CondIni[1]

longCondition = longCond and CondIni[1] == -1
shortCondition = shortCond and CondIni[1] == 1

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ══════════════════════════════════════════════════════════════════════════════

// Time filter
timePeriod = time >= startDate

// Check if not in trade
notInTrade = strategy.position_size <= 0

// Calculate TP/SL levels
longTP = strategy.position_avg_price * (1 + tpPercent / 100)
longSL = strategy.position_avg_price * (1 - slPercent / 100)
shortTP = strategy.position_avg_price * (1 - tpPercent / 100)
shortSL = strategy.position_avg_price * (1 + slPercent / 100)

// Execute trades
if longCondition and timePeriod and notInTrade
    strategy.entry("Long", strategy.long, comment="BUY")
    strategy.exit("Exit Long", "Long", limit=longTP, stop=longSL, comment="TP/SL")

if shortCondition and timePeriod and notInTrade
    strategy.entry("Short", strategy.short, comment="SELL")
    strategy.exit("Exit Short", "Short", limit=shortTP, stop=shortSL, comment="TP/SL")

// Trailing Stop
if trailingStop and strategy.position_size > 0
    strategy.exit("Trailing Long", "Long", trail_points=close * trailingPercent / 100 / syminfo.mintick, trail_offset=close * trailingPercent / 100 / syminfo.mintick)

if trailingStop and strategy.position_size < 0
    strategy.exit("Trailing Short", "Short", trail_points=close * trailingPercent / 100 / syminfo.mintick, trail_offset=close * trailingPercent / 100 / syminfo.mintick)

// ══════════════════════════════════════════════════════════════════════════════
// VISUALIZATION
// ══════════════════════════════════════════════════════════════════════════════

// Plot Range Filter
filtplot = plot(filt, color=filtcolor, linewidth=2, title="Range Filter")

// Plot Target Bands
if showBands
    hbandplot = plot(hband, color=color.new(upColor, 70), title="High Target")
    lbandplot = plot(lband, color=color.new(downColor, 70), title="Low Target")
    
    // Fills
    fill(hbandplot, filtplot, color=color.new(upColor, 90), title="High Target Range")
    fill(lbandplot, filtplot, color=color.new(downColor, 90), title="Low Target Range")

// Background color
if showBackground
    bgcolor(upward > 0 ? bgUpColor : downward > 0 ? bgDownColor : na, title="Trend Background")

// Bar Color
barcolor(barcolor)

// Plot Signals
if showSignals
    plotshape(longCondition, title="Buy Signal", text="BUY", textcolor=color.white, 
              style=shape.labelup, size=size.small, location=location.belowbar, 
              color=color.new(color.green, 20))
    
    plotshape(shortCondition, title="Sell Signal", text="SELL", textcolor=color.white, 
              style=shape.labeldown, size=size.small, location=location.abovebar, 
              color=color.new(color.red, 20))

// ══════════════════════════════════════════════════════════════════════════════
// INFORMATION PANEL
// ══════════════════════════════════════════════════════════════════════════════

// Current trend info
var table infoPanel = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), 
                                frame_width=1, frame_color=color.gray)

if barstate.islast
    table.cell(infoPanel, 0, 0, "Trend:", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, upward > 0 ? "UP" : downward > 0 ? "DOWN" : "NEUTRAL", 
               text_color=upward > 0 ? color.green : downward > 0 ? color.red : color.gray, 
               text_size=size.small)
    
    table.cell(infoPanel, 0, 1, "Filter:", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, str.tostring(filt, format.mintick), 
               text_color=filtcolor, text_size=size.small)
    
    table.cell(infoPanel, 0, 2, "Position:", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 2, strategy.position_size > 0 ? "LONG" : 
               strategy.position_size < 0 ? "SHORT" : "FLAT", 
               text_color=strategy.position_size > 0 ? color.green : 
               strategy.position_size < 0 ? color.red : color.gray, text_size=size.small)
    
    table.cell(infoPanel, 0, 3, "P&L:", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 3, str.tostring(strategy.openprofit, format.mintick), 
               text_color=strategy.openprofit > 0 ? color.green : 
               strategy.openprofit < 0 ? color.red : color.gray, text_size=size.small)
    
    table.cell(infoPanel, 0, 4, "Equity:", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 4, "$" + str.tostring(strategy.equity, format.mintick), 
               text_color=color.white, text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(longCondition, title="🟢 Buy Signal", message="Range Filter: BUY signal on {{ticker}} at {{close}}")
alertcondition(shortCondition, title="🔴 Sell Signal", message="Range Filter: SELL signal on {{ticker}} at {{close}}")
alertcondition(longCondition or shortCondition, title="⚡ Any Signal", message="Range Filter: Signal on {{ticker}} at {{close}}")

// ══════════════════════════════════════════════════════════════════════════════
// END OF SCRIPT
// ══════════════════════════════════════════════════════════════════════════════
